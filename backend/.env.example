# App Settings
# SmartKiosk application base variables
APP_NAME=SmartKiosk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Nairobi
APP_URL=http://localhost:8000

# Database Settings
# Supports pgsql for PostgreSQL (e.g. Docker, Neon DB)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smartkiosk
DB_USERNAME=smartkiosk_user
DB_PASSWORD=secret
DB_SSLMODE=prefer

# Redis Connection Settings
# Configured for standard TCP or Upstash TLS
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_SCHEME=tcp

# Cache / Queue / Session Drivers
# Recommended to use redis for production, file/database for fallback
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Sanctum Auth
# CORS Allowed stateful domains (e.g. Next.js port)
SANCTUM_STATEFUL_DOMAINS=localhost:3000
FRONTEND_URL=http://localhost:3000

# Cloudinary Integration (Image Uploads)
# Get credentials from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# M-Pesa Daraja STK Push Integration
# Daraja sandbox or production credentials
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:8000/api/v1/payments/mpesa/callback

# Africa's Talking (SMS) Gateway
# SMS messaging credentials
AT_USERNAME=sandbox
AT_API_KEY=

# Resend (Email)
# Resend transactional email API keys
RESEND_API_KEY=re_

# Sentry Performance & Error Tracking
# Error analytics DNS key
SENTRY_LARAVEL_DSN=

# Frontend App URL (for reset password links)
APP_FRONTEND_URL=http://localhost:3000
