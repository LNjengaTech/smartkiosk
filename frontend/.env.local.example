# Frontend Environment Variables Template
# SmartKiosk Next.js 14 App

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=SmartKiosk
NEXT_PUBLIC_APP_VERSION=1.0.0

# Offline sync batch window in milliseconds (default: 5000ms)
NEXT_PUBLIC_SYNC_BATCH_WINDOW_MS=5000

# Shared secret for internal email rendering API
EMAIL_RENDER_SECRET=

